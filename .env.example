# Copy to .env and fill in. .env is gitignored.

# --- LLM backend switch: "ollama" (dev) or "claude" (final demo only) ---
LLM_BACKEND=ollama

# --- ReAct loop: "custom" (robust on local models) or "prebuilt" (Claude demo) ---
REACT_MODE=custom

# --- Reflection / self-critique pass to reduce hallucination (true|false) ---
# After the loop drafts a final answer, the model re-checks every claim against
# the exact tool observations and revises anything unsupported.
REACT_REFLECTION=true

# --- Ollama (local dev) ---
OLLAMA_MODEL=qwen2.5:14b          # or llama3.1:8b if RAM < 16GB
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Claude (final demo only) ---
CLAUDE_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# --- LangSmith tracing (free tier) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=pwi-agent
LANGCHAIN_API_KEY=
